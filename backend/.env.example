RACK_ENV=development

# To download the about me data from private github repo
GITHUB_ACCESS_TOKEN=CHANGE_ME
ABOUTME_DATA_GITHUB_REPO_NAME=username/github-repo-name
# To store the about me data in the local file system
ABOUTME_DATA_DIR_PATH=./external/data

EMBEDDING_PROVIDER=tei/voyage
EMBEDDING_BASE_URL=http://embeddings:80
EMBEDDING_STARTUP_TIMEOUT_SECS=120
VOYAGE_API_KEY=CHANGE_ME
VOYAGE_MODEL=voyage-4-lite

# Optional: used only when you want model-composed final answers
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Character-based chunking for retrieval index
RAG_CHUNK_SIZE_CHARS=2000
RAG_CHUNK_OVERLAP_PERCENT=10

# --- Session + Auth0 (OmniAuth server-side; optional if you skip /auth routes) ---
SESSION_SECRET=change-me-in-production
# Comma-separated origins allowed in CORS and for return_to validation (first entry is primary)
FRONTEND_ORIGIN=http://localhost:3000
# Auth0 Regular Web App (same tenant as social connections)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# Optional: full callback URL for Auth0 dashboard docs (must include /auth/auth0/callback)
AUTH0_CALLBACK_URL=https://YOUR_API_HOST/auth/auth0/callback
# Hosts allowed by Sinatra host_authorization (production); comma-separated
APP_PERMITTED_HOSTS=
