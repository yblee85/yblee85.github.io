# To download the about me data from private github repo
GITHUB_ACCESS_TOKEN=CHANGE_ME
ABOUTME_DATA_GITHUB_REPO_NAME=username/github-repo-name
# To store the about me data in the local file system
ABOUTME_DATA_DIR_PATH=./external/data

EMBEDDING_PROVIDER=tei/voyage
EMBEDDING_BASE_URL=http://embeddings:80
EMBEDDING_STARTUP_TIMEOUT_SECS=120
VOYAGE_API_KEY=CHANGE_ME
VOYAGE_MODEL=voyage-4-lite

# Optional: used only when you want model-composed final answers
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# Character-based chunking for retrieval index
RAG_CHUNK_SIZE_CHARS=2000
RAG_CHUNK_OVERLAP_PERCENT=10
