RACK_ENV=development

# To download the about me data from private github repo
GITHUB_ACCESS_TOKEN=
ABOUTME_DATA_GITHUB_REPO_NAME=
ABOUTME_DATA_DIR_PATH=./external_example/data

# tei or voyage
EMBEDDING_PROVIDER=tei
EMBEDDING_BASE_URL=http://embeddings:80
EMBEDDING_STARTUP_TIMEOUT_SECS=120
VOYAGE_API_KEY=
VOYAGE_MODEL=

ANTHROPIC_API_KEY=CHANGE_ME
ANTHROPIC_MODEL=claude-haiku-4-5

# Character-based chunking for retrieval index
RAG_CHUNK_SIZE_CHARS=2000
RAG_CHUNK_OVERLAP_PERCENT=10

SESSION_SECRET=change-me-in-production
# Comma-separated origins allowed in CORS and for return_to validation (first entry is primary)
FRONTEND_ORIGIN=http://localhost:3000

# Auth0 Regular Web App
AUTH0_DOMAIN=CHANGE_ME.auth0.com
AUTH0_CLIENT_ID=CHANGE_ME
AUTH0_CLIENT_SECRET=CHANGE_ME
AUTH0_CALLBACK_URL=http://localhost:3001/auth/auth0/callback
APP_PERMITTED_HOSTS=http://localhost:3001

# Chat rate limit
# Allow user to make 10 requests per hour
CHAT_MAX_REQUESTS_PER_HOUR_PER_USER=10

# Slack notification
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=

# QA service
MAX_CHAT_HISTORY=6
RAG_MIN_SCORE=
RAG_K=

# admin user emails, comma separated
ADMIN_USER=